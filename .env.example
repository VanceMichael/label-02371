# ============================================================
# 酒店预订系统 - 环境变量配置
# 复制此文件为 .env 后修改，docker-compose 启动时自动加载
# ============================================================

# [必填] JWT 签名密钥，至少 256 位（32 字符以上）
# 生产环境务必替换为随机强密钥
JWT_SECRET=your-production-secret-key-at-least-256-bits-long

# [可选] Token 过期时间（毫秒），默认 24 小时
JWT_EXPIRATION=86400000

# [可选] 激活的 Spring Profile：dev / prod
SPRING_PROFILES_ACTIVE=dev

# [可选] 日志级别：debug / info / warn / error
LOG_LEVEL=info

# [可选] CORS 允许的源（逗号分隔），生产环境应限定为实际域名
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082

# [可选] MySQL root 密码
MYSQL_ROOT_PASSWORD=root123
